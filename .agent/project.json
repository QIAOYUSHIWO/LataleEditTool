{
  "version": "1.0",
  "stack": "dotnet",
  "coverage_threshold": 80,
  "commands": {
    "lint": "dotnet format LdtEditor/LdtEditor.csproj --verify-no-changes",
    "test": "dotnet test LdtEditor/LdtEditor.csproj",
    "coverage": "dotnet test LdtEditor/LdtEditor.csproj --collect:\"XPlat Code Coverage\"",
    "security": "dotnet list LdtEditor/LdtEditor.csproj package --vulnerable"
  },
  "stacks": {
    "go": {
      "detect": [
        "go.mod"
      ],
      "implementation_glob": "*.go",
      "test_suffix": "_test.go",
      "exclude_dirs": [
        "vendor",
        ".git",
        ".agent",
        "node_modules"
      ],
      "commands": {
        "lint": "golangci-lint run --out-format=json > .agent/logs/lint.json",
        "test": "go test ./... -race -json > .agent/logs/test.json",
        "coverage": "go test -coverprofile=.agent/logs/coverage.out ./...",
        "security": "gosec -fmt json -out .agent/logs/gosec.json ./... >/dev/null"
      },
      "required_tools": {
        "lint": [
          "golangci-lint"
        ],
        "test": [
          "go"
        ],
        "coverage": [
          "go"
        ],
        "security": [
          "gosec",
          "jq"
        ]
      }
    },
    "node": {
      "detect": [
        "package.json"
      ],
      "commands": {
        "lint": "npm run lint",
        "test": "npm test",
        "coverage": "npm run coverage",
        "security": "npm audit --audit-level=high"
      },
      "required_tools": {
        "lint": [
          "npm"
        ],
        "test": [
          "npm"
        ],
        "coverage": [
          "npm"
        ],
        "security": [
          "npm"
        ]
      }
    },
    "python": {
      "detect": [
        "pyproject.toml",
        "requirements.txt",
        "setup.py"
      ],
      "commands": {
        "lint": "ruff check .",
        "test": "pytest",
        "coverage": "pytest --cov=. --cov-fail-under=80",
        "security": "bandit -r ."
      },
      "required_tools": {
        "lint": [
          "ruff"
        ],
        "test": [
          "pytest"
        ],
        "coverage": [
          "pytest"
        ],
        "security": [
          "bandit"
        ]
      }
    },
    "rust": {
      "detect": [
        "Cargo.toml"
      ],
      "commands": {
        "lint": "cargo clippy -- -D warnings",
        "test": "cargo test",
        "coverage": "cargo test",
        "security": "cargo audit"
      },
      "required_tools": {
        "lint": [
          "cargo"
        ],
        "test": [
          "cargo"
        ],
        "coverage": [
          "cargo"
        ],
        "security": [
          "cargo"
        ]
      }
    },
    "cpp": {
      "detect": [
        "CMakeLists.txt",
        "Makefile"
      ],
      "implementation_glob": "*.{cpp,cc,cxx,hpp,h}",
      "test_suffix": "_test.cpp",
      "exclude_dirs": [
        "build",
        ".git",
        ".agent",
        "node_modules"
      ],
      "commands": {
        "lint": "clang-tidy src/**/*.cpp",
        "test": "ctest --test-dir build",
        "coverage": "cmake --build build --target coverage",
        "security": "echo \"[SECURITY] C++ 项目建议使用 clang-tidy static analyzer 和 ASan/UBSan\" && exit 1"
      },
      "required_tools": {
        "lint": [
          "clang-tidy"
        ],
        "test": [
          "cmake",
          "ctest"
        ],
        "coverage": [
          "cmake",
          "gcov"
        ],
        "security": [
          "clang-tidy"
        ]
      }
    },
    "java": {
      "detect": [
        "pom.xml",
        "build.gradle",
        "build.gradle.kts"
      ],
      "implementation_glob": "*.java",
      "test_suffix": "Test.java",
      "exclude_dirs": [
        ".git",
        ".agent",
        "node_modules",
        "target"
      ],
      "commands": {
        "lint": "mvn checkstyle:check",
        "test": "mvn test",
        "coverage": "mvn jacoco:report",
        "security": "mvn dependency-check:check"
      },
      "required_tools": {
        "lint": [
          "mvn"
        ],
        "test": [
          "mvn"
        ],
        "coverage": [
          "mvn"
        ],
        "security": [
          "mvn"
        ]
      }
    },
    "dotnet": {
      "detect": [
        "*.csproj",
        "*.sln",
        "global.json"
      ],
      "implementation_glob": "*.cs",
      "test_suffix": "Tests.cs",
      "exclude_dirs": [
        ".git",
        ".agent",
        "node_modules",
        "bin",
        "obj"
      ],
      "commands": {
        "lint": "dotnet format --verify-no-changes",
        "test": "dotnet test",
        "coverage": "dotnet test --collect:\"XPlat Code Coverage\"",
        "security": "dotnet list package --vulnerable"
      },
      "required_tools": {
        "lint": [
          "dotnet"
        ],
        "test": [
          "dotnet"
        ],
        "coverage": [
          "dotnet"
        ],
        "security": [
          "dotnet"
        ]
      }
    },
    "generic": {
      "detect": [],
      "commands": {
        "lint": "echo \"[LINT] 未配置 lint 命令，请手动配置\" && exit 0",
        "test": "echo \"[TEST] 未配置测试命令，请手动配置\" && exit 0",
        "coverage": "echo \"[COVERAGE] 未配置覆盖率命令，请手动配置\" && exit 0",
        "security": "echo \"[SECURITY] 未配置安全扫描命令，请手动配置\" && exit 1"
      },
      "required_tools": {
        "lint": [],
        "test": [],
        "coverage": [],
        "security": []
      }
    }
  }
}