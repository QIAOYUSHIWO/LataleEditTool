{
  "_comment": "SCALE OS 生成的 Cursor 通用配置；已按本仓库 .NET 路径合并，请按 Cursor 官方文档并入 MCP/权限配置",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(dotnet:*)",
      "Bash(git:*)",
      "Write(LdtEditor/**)",
      "Write(tools/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(DROP:*)",
      "Write(.env*)"
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    }
  }
}
